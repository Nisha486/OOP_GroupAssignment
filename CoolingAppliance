package SDGApplianceModule.entity;

public class CoolingAppliance extends Appliance {
    private double dutyCycle;
    private int thermostatSetting;

    public CoolingAppliance(String applianceName, double powerRate, double hoursUsed,
                            double dutyCycle) {
        super(applianceName, powerRate, hoursUsed);
        this.dutyCycle = dutyCycle;
        this.thermostatSetting = thermostatSetting;
    }

    // Getters and Setters
    public double getDutyCycle() {
        return dutyCycle;
    }
    public void setDutyCycle(double dutyCycle) {
        this.dutyCycle = dutyCycle;
    }

    public int getThermostatSetting() {
        return thermostatSetting;
    }
    public void setThermostatSetting(int thermostatSetting) {
        this.thermostatSetting = thermostatSetting;
    }

    @Override
    public double calculateEnergyUsed() {
        return super.calculateEnergyUsed() * dutyCycle;
    }

    @Override
    public String toString() {
        return ("Appliance: " + getApplianceName() +
                " (Cooling)" +
                "\n Rate of power used in (Watts): " + getPowerRate() +
                "\nConsumption Hours: " + getHoursUsed() +
                "\nThermostat Setting: " + thermostatSetting + "°C" +
                "\nDuty Cycle: " + (dutyCycle * 100) + "%" +
                "\nEnergy Used: " + calculateEnergyUsed() + " kWh");
    }
}
